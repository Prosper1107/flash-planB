# ============================================================
# FLASH WALLET — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# URL de l'API Flash
# Staging (développement) :
NEXT_PUBLIC_FLASH_API_URL=https://staging.bitcoinflash.xyz

# Production (quand vous avez accès) :
# NEXT_PUBLIC_FLASH_API_URL=https://api.bitcoinflash.xyz

# Environnement
NODE_ENV=development

# URL de l'application (pour les métadonnées OG)
NEXT_PUBLIC_APP_URL=http://localhost:3000
